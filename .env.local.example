# Sheet IDs — from the URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
LEADS_SHEET_ID=your_leads_sheet_id_here
OUTREACH_SHEET_ID=your_outreach_log_sheet_id_here

# Tab names (default: Sheet1 — change if your tab has a different name)
LEADS_SHEET_NAME=Sheet1
OUTREACH_SHEET_NAME=Sheet1

# Google Service Account credentials (from downloaded JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
